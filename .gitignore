app/static/hero-covers/**/*.tmp.jpg
app/static/hero-covers/**/*.tmp.*
app/static/hero-covers/raw/

# New structure: keep only themed covers under home/about, ignore legacy flat files
app/static/hero-covers/*.jpg
!app/static/hero-covers/home/*.jpg
!app/static/hero-covers/about/*.jpg
app/static/hero-covers/**/_original_backup_*/
