FLASK_ENV=development

# Optional deployment timestamp.
# Should be generated or updated during deployment.
# Format: ISO 8601 with timezone.
# APP_DEPLOYED_AT=2026-03-17T18:30:00+08:00

SECRET_KEY=replace-with-a-random-secret-key

# Legacy admin password, if still supported by the app.
ADMIN_PASSWORD=replace-with-a-strong-legacy-password

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-admin-password-6plus

DATABASE_URL=sqlite:///instance/app.db

UPLOAD_FOLDER=uploads/gpx
MEDIA_UPLOAD_FOLDER=uploads/media
BACKUP_DIR=backups

POSTGRES_DB=replace-with-postgres-db
POSTGRES_USER=replace-with-postgres-user
POSTGRES_PASSWORD=replace-with-strong-postgres-password

MAX_GPX_BYTES=5242880
MAX_MEDIA_BYTES=10485760

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

REQUEST_CONSOLE_LOG_ENABLED=false
ACCESS_LOG_ASYNC=true
ACCESS_LOG_BATCH_SIZE=100
ACCESS_LOG_FLUSH_INTERVAL=1.0
ACCESS_LOG_QUEUE_MAX=5000

GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=30
GUNICORN_KEEPALIVE=5