FLASK_ENV=development
APP_VERSION=v3.2.3
APP_DEPLOYED_AT=2026-03-17T18:30:00+08:00
SECRET_KEY=replace-with-a-random-secret-key
ADMIN_PASSWORD=replace-with-a-strong-legacy-password
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-admin-password-6plus
DATABASE_URL=sqlite:///instance/app.db
UPLOAD_FOLDER=uploads/gpx
BACKUP_DIR=backups
POSTGRES_DB=replace-with-postgres-db
POSTGRES_USER=replace-with-postgres-user
POSTGRES_PASSWORD=replace-with-strong-postgres-password
MAX_GPX_BYTES=5242880
MAX_MEDIA_BYTES=10485760
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
